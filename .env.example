# Shared / local Docker
DATABASE_URL=postgres://iesdata:iesdata@localhost:5432/iesdata
REDIS_URL=redis://localhost:6379

# API (apps/api)
PORT=3001
NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long!
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d
CORS_ORIGINS=http://localhost:3000
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
THROTTLE_API_KEY_LIMIT=120
DAILY_REQUEST_QUOTA=2000
# Opt-in Redis Sentinel HA (overrides REDIS_URL when set):
# REDIS_SENTINELS=localhost:26379,localhost:26380,localhost:26381
# REDIS_MASTER_NAME=mymaster

# Seed INEP
CENSUP_ANO=2024
CENSUP_DATA_DIR=./data

# Web (apps/web) — também em .env.local do Next
NEXT_PUBLIC_API_URL=http://localhost:3001/api
